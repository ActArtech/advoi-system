# ── Application ──────────────────────────────────────────────
ADVOI_ENV=development
ADVOI_LOG_LEVEL=INFO
ADVOI_API_PORT=8000
ADVOI_VOICE_PORT=8080

# ── Postgres ─────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=advoi
POSTGRES_PASSWORD=advoi
POSTGRES_DB=advoi
DATABASE_URL=postgresql://advoi:advoi@localhost:5432/advoi

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ── LiveKit (self-hosted — no LiveKit Cloud account) ───────
LIVEKIT_USE_DEV_KEYS=true
LIVEKIT_HOST=localhost
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_INTERNAL_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_HOST_PORT=7880

# ── LLM / Routing ────────────────────────────────────────────
# OpenRouter (preferred — clapart voicecomp pattern)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Direct OpenAI fallback when OPENROUTER_API_KEY is unset
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_MODEL=openai/gpt-4o-mini
OPENAI_STT_MODEL=openai/gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=openai/tts-1
OPENAI_TTS_VOICE=alloy
ROUTING_FALLBACK_MODEL=gpt-4o-mini

# ── FirstMate / Squads (Discord bridge) ──────────────────────
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=
FIRSTMATE_CHANNEL_ID=

# ── Observability (SigNoz / OTLP) ───────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=advoi
SIGNOZ_ENDPOINT=

# ── Guardian / Security ──────────────────────────────────────
ADVOI_CONFIRMATION_REQUIRED=true
ADVOI_ALLOWED_ORIGINS=http://localhost:3000