FROM python:3.11-slim

WORKDIR /app
RUN apt-get update \
    && apt-get install -y --no-install-recommends docker-cli \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml README.md ./
COPY advoi/ ./advoi/
COPY scripts/fm-bridge.sh ./scripts/fm-bridge.sh
RUN chmod +x ./scripts/fm-bridge.sh

# [observability] required for OTEL_ENABLED=true (moat R6 staging)
RUN pip install --no-cache-dir ".[observability]"

EXPOSE 8000
CMD ["advoi-api"]