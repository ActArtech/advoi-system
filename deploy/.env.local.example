# ADVoi local test stack — copy to deploy/.env

PROJECT_SLUG=advoi
ADVOI_ENV=local
ADVOI_LOG_LEVEL=INFO
ADVOI_AGENT_INTERVAL_SECS=30
ADVOI_PREWARM_AGENTS=true
ADVOI_FRAME_MOCK=true
ADVOI_CONFIRMATION_REQUIRED=true

ADVOI_API_HOST_PORT=8010
ADVOI_API_PORT=8010
ADVOI_VOICE_PORT=8011
ADVOI_WEB_PORT=3000
ADVOI_MEMORY_BRIDGE_PORT=8095

NEXT_PUBLIC_LIVEKIT_TOKEN_ENDPOINT=http://localhost:8010/api/livekit/token
NEXT_PUBLIC_ADVOI_API_URL=http://localhost:8010/api
ADVOI_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

POSTGRES_USER=advoi
POSTGRES_PASSWORD=advoi
POSTGRES_DB=advoi
POSTGRES_PORT=5438
DATABASE_URL=postgresql://advoi:advoi@postgres:5432/advoi

REDIS_PORT=6382
REDIS_URL=redis://redis:6379/0

LIVEKIT_USE_DEV_KEYS=true
LIVEKIT_HOST=localhost
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_INTERNAL_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_HOST_PORT=7880
LIVEKIT_RTC_TCP_PORT=7881

FIRSTMATE_FLEET_PATH=/opt/firstmate-fleet
HERMES_CONTAINER=hermes
MEMORY_PROVIDER=hindsight
HINDSIGHT_BRIDGE_URL=http://advoi-memory-bridge:8095

OPENROUTER_API_KEY=
OPENAI_API_KEY=
DEFAULT_MODEL=openai/gpt-4o-mini
OPENAI_STT_MODEL=openai/gpt-4o-transcribe
OPENAI_TTS_MODEL=openai/tts-1
OPENAI_TTS_VOICE=alloy