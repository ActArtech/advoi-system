# /var/www/advoi/.env.staging — copied to staging/deploy/.env on deploy
# Isolated from /opt/advoi (legacy single-tier) and advoi-live

COMPOSE_PROJECT_NAME=advoi-staging
PROJECT_SLUG=advoi-staging
STOREFRONT_HOST=advoi-staging.keyteller.com

ADVOI_ENV=staging
ADVOI_LOG_LEVEL=INFO
ADVOI_API_HOST_PORT=8012
ADVOI_API_PORT=8012
ADVOI_VOICE_PORT=8013
ADVOI_WEB_PORT=3000
NEXT_PUBLIC_LIVEKIT_TOKEN_ENDPOINT=https://advoi-staging.keyteller.com/api/livekit/token
NEXT_PUBLIC_ADVOI_API_URL=https://advoi-staging.keyteller.com/api

POSTGRES_HOST=postgres
POSTGRES_PORT=5439
POSTGRES_USER=advoi
POSTGRES_PASSWORD=change-me-advoi-staging-pg
POSTGRES_DB=advoi_staging
DATABASE_URL=postgresql://advoi:change-me-advoi-staging-pg@postgres:5432/advoi_staging

REDIS_HOST=redis
REDIS_PORT=6383
REDIS_URL=redis://redis:6379/0

LIVEKIT_USE_DEV_KEYS=true
LIVEKIT_HOST=livekit.advoi-staging.keyteller.com
LIVEKIT_URL=wss://livekit.advoi-staging.keyteller.com
LIVEKIT_INTERNAL_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_HOST_PORT=7882
LIVEKIT_RTC_TCP_PORT=7883
LIVEKIT_RTC_UDP_RANGE=51100-51200

FIRSTMATE_FLEET_PATH=/opt/firstmate-fleet
FIRSTMATE_TRIGGER_SCRIPT=/opt/firstmate-fleet/scripts/fm-hermes-trigger.sh
ADVOI_FM_BRIDGE_SCRIPT=/app/scripts/fm-bridge.sh
HERMES_CONTAINER=hermes

AETHER_PORTFOLIO_PATH=data/aether/portfolio.json

MEMORY_PROVIDER=hindsight
HINDSIGHT_MODE=local
HINDSIGHT_BRIDGE=hermes
HINDSIGHT_BRIDGE_URL=http://advoi-memory-bridge:8095
HINDSIGHT_BANK_ID=advoi-staging-portfolio
ADVOI_MEMORY_BRIDGE_PORT=8096

LETTA_ENABLED=false
LETTA_BASE_URL=http://letta:8283
LETTA_AGENT_ID=advoi-executive-staging
ADVOI_OPERATIONAL_STORE=data/operational-memory.jsonl
GUARDIAN_LOG_PATH=/var/www/advoi/staging/docs/error-log/guardian-events.jsonl

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
DEFAULT_MODEL=openai/gpt-4o-mini
OPENAI_STT_MODEL=openai/gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=openai/tts-1
OPENAI_TTS_VOICE=alloy

ADVOI_CONFIRMATION_REQUIRED=true
ADVOI_AGENT_INTERVAL_SECS=15
ADVOI_PREWARM_AGENTS=true
ADVOI_ALLOWED_ORIGINS=https://advoi-staging.keyteller.com

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=advoi-staging