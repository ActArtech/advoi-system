# ADVoi staging — copy to deploy/.env on VPS (/opt/advoi)
# Isolated ports — does not bind host 5432/6379 (other projects may use them)

PROJECT_SLUG=advoi
STOREFRONT_HOST=advoi.keyteller.com

ADVOI_ENV=staging
ADVOI_LOG_LEVEL=INFO
ADVOI_API_PORT=8010
ADVOI_VOICE_PORT=8011

# Internal compose ports (host mapping — pick unused ports on VPS)
POSTGRES_HOST=postgres
POSTGRES_PORT=5438
POSTGRES_USER=advoi
POSTGRES_PASSWORD=change-me-advoi-pg
POSTGRES_DB=advoi
DATABASE_URL=postgresql://advoi:change-me-advoi-pg@postgres:5432/advoi

REDIS_HOST=redis
REDIS_PORT=6382
REDIS_URL=redis://redis:6379/0

# LiveKit (cloud or self-hosted — fill when ready)
LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Bridge to existing fleet (read-only triggers — do not overwrite fleet config)
FIRSTMATE_FLEET_PATH=/opt/firstmate-fleet
FIRSTMATE_TRIGGER_SCRIPT=/opt/firstmate-fleet/scripts/fm-hermes-trigger.sh
HERMES_CONTAINER=hermes

# Memory stack (ADR-026) — Hindsight (strategic) + optional Letta (operational)
MEMORY_PROVIDER=hindsight
# MEMORY_PROVIDER=both          # after scripts/memory-setup-letta.sh
HERMES_CONTAINER=hermes
HINDSIGHT_MODE=local
HINDSIGHT_BRIDGE=hermes
HINDSIGHT_BANK_ID=advoi-portfolio
# HINDSIGHT_API_KEY=hs_...    # cloud mode only (ui.hindsight.vectorize.io)
# HINDSIGHT_API_URL=https://api.hindsight.vectorize.io
LETTA_ENABLED=false
LETTA_BASE_URL=http://127.0.0.1:8283
LETTA_AGENT_ID=advoi-executive
LETTA_API_KEY=
GUARDIAN_LOG_PATH=/opt/advoi/docs/error-log/guardian-events.jsonl

# Discord (optional — same pattern as fleet)
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=
FIRSTMATE_CHANNEL_ID=

# Model routing
OPENAI_API_KEY=
DEFAULT_MODEL=gpt-4o-mini

ADVOI_CONFIRMATION_REQUIRED=true
ADVOI_ALLOWED_ORIGINS=https://advoi.keyteller.com

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=advoi