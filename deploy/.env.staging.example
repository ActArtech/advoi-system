# ADVoi staging — copy to deploy/.env on VPS (/opt/advoi)
# Isolated ports — does not bind host 5432/6379 (other projects may use them)

PROJECT_SLUG=advoi
STOREFRONT_HOST=advoi.keyteller.com

ADVOI_ENV=staging
ADVOI_LOG_LEVEL=INFO
# Host port published to Traefik / localhost (container always listens on 8000)
ADVOI_API_HOST_PORT=8010
ADVOI_API_PORT=8010
ADVOI_VOICE_PORT=8011
ADVOI_WEB_PORT=3000
NEXT_PUBLIC_LIVEKIT_TOKEN_ENDPOINT=https://advoi.keyteller.com/api/livekit/token
NEXT_PUBLIC_ADVOI_API_URL=https://advoi.keyteller.com/api

# Internal compose ports (host mapping — pick unused ports on VPS)
POSTGRES_HOST=postgres
POSTGRES_PORT=5438
POSTGRES_USER=advoi
POSTGRES_PASSWORD=change-me-advoi-pg
POSTGRES_DB=advoi
DATABASE_URL=postgresql://advoi:change-me-advoi-pg@postgres:5432/advoi

REDIS_HOST=redis
REDIS_PORT=6382
REDIS_URL=redis://redis:6379/0

# LiveKit — self-hosted in compose (no LiveKit Cloud API required)
LIVEKIT_USE_DEV_KEYS=true
LIVEKIT_HOST=livekit.advoi.keyteller.com
LIVEKIT_URL=wss://livekit.advoi.keyteller.com
LIVEKIT_INTERNAL_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_HOST_PORT=7880
LIVEKIT_RTC_TCP_PORT=7881

# Bridge to existing fleet (read-only triggers — do not overwrite fleet config)
FIRSTMATE_FLEET_PATH=/opt/firstmate-fleet
FIRSTMATE_TRIGGER_SCRIPT=/opt/firstmate-fleet/scripts/fm-hermes-trigger.sh
ADVOI_FM_BRIDGE_SCRIPT=/app/scripts/fm-bridge.sh
HERMES_CONTAINER=hermes

# Aether portfolio registry (ventures, frame routes, gate alignment)
AETHER_PORTFOLIO_PATH=data/aether/portfolio.json

# Memory stack (ADR-026) — Hindsight (strategic) + optional Letta (operational)
MEMORY_PROVIDER=hindsight
# MEMORY_PROVIDER=both          # after scripts/memory-setup-letta.sh
HERMES_CONTAINER=hermes
HINDSIGHT_MODE=local
HINDSIGHT_BRIDGE=hermes
HINDSIGHT_BRIDGE_URL=http://advoi-memory-bridge:8095
HINDSIGHT_BANK_ID=advoi-portfolio
ADVOI_MEMORY_BRIDGE_PORT=8095
# HINDSIGHT_API_KEY=hs_...    # cloud mode only (ui.hindsight.vectorize.io)
# HINDSIGHT_API_URL=https://api.hindsight.vectorize.io
LETTA_ENABLED=false
# After scripts/memory-setup-letta.sh: LETTA_BASE_URL=http://letta:8283 + deploy/docker-compose.letta.yml overlay
LETTA_BASE_URL=http://letta:8283
LETTA_AGENT_ID=advoi-executive
LETTA_API_KEY=
ADVOI_OPERATIONAL_STORE=data/operational-memory.jsonl
GUARDIAN_LOG_PATH=/opt/advoi/docs/error-log/guardian-events.jsonl

# Discord (optional — same pattern as fleet)
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=
FIRSTMATE_CHANNEL_ID=

# Model routing (OpenRouter preferred — same as clapart voicecomp)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
DEFAULT_MODEL=openai/gpt-4o-mini
OPENAI_STT_MODEL=openai/gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=openai/tts-1
OPENAI_TTS_VOICE=alloy
# Optional: bash scripts/sync-llm-keys-from-clapart.sh copies keys from /opt/clapart/deploy/.env

ADVOI_CONFIRMATION_REQUIRED=true
ADVOI_AGENT_INTERVAL_SECS=15
ADVOI_PREWARM_AGENTS=true
ADVOI_ALLOWED_ORIGINS=https://advoi.keyteller.com

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=advoi