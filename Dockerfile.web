FROM node:22-alpine AS build
WORKDIR /app
COPY web/package.json web/package-lock.json* ./
RUN npm ci
COPY web/ ./
RUN find node_modules/.bin -type f -exec chmod +x {} + 2>/dev/null || true
ARG NEXT_PUBLIC_LIVEKIT_TOKEN_ENDPOINT
ARG NEXT_PUBLIC_ADVOI_API_URL
ENV NEXT_PUBLIC_LIVEKIT_TOKEN_ENDPOINT=$NEXT_PUBLIC_LIVEKIT_TOKEN_ENDPOINT
ENV NEXT_PUBLIC_ADVOI_API_URL=$NEXT_PUBLIC_ADVOI_API_URL
RUN npm run build

FROM node:22-alpine AS run
WORKDIR /app
ENV NODE_ENV=production
COPY --from=build /app/.next/standalone ./
COPY --from=build /app/.next/static ./.next/static
COPY --from=build /app/public ./public
EXPOSE 3000
CMD ["node", "server.js"]