FROM python:3.11-slim

WORKDIR /app
RUN apt-get update \
    && apt-get install -y --no-install-recommends docker.io \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml README.md ./
COPY advoi/ ./advoi/
COPY scripts/fm-bridge.sh ./scripts/fm-bridge.sh
RUN chmod +x ./scripts/fm-bridge.sh

# voice + observability so OTEL_ENABLED works in the voice agent container
RUN pip install --no-cache-dir ".[voice,observability]"

EXPOSE 8080
CMD ["advoi-voice"]